{
  "name": "adblitz",
  "version": "1.0.0",
  "description": "AdBlitz - AI Ad Video Generator",
  "private": true,
  "scripts": {
    "dev": "npm run kill:ports && npm run start:all",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && PORT=3000 npm run dev",
    "start:frontend": "cd web && PORT=3001 npm start",
    "kill:ports": "kill-port 3000 3001 2>/dev/null || true",
    "kill:3000": "kill-port 3000",
    "start": "cd backend && npm start",
    "build": "cd backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1"
  }
}
